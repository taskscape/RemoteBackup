{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "FileLogging": {
    "Path": "logs\\backup.log",
    "MinimumLevel": "Information"
  },
  "BackupOptions": {
    "Backups": [
      {
        "Name": "TestUpload",
        "BackupType": "FTP_UPLOAD",
        "Host": "YOUR_FTP_HOST",
        "Port": 21,
        "Username": "YOUR_USERNAME",
        "Password": "YOUR_PASSWORD",
        "LocalPath": "C:\\Backups\\Test",
        "RemotePath": "/backup",
        "Encryption": "Explicit",
        "Passive": true,
        "AllowInvalidCertificate": true
      }
    ]
  },
  "ServiceSettings": {
    "StartHour": 2,
    "StartMinute": 0
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "FileLogging": {
    "Path": "logs\\backup.log",
    "MinimumLevel": "Information",
    "RetentionDays": 7
  },
  "BackupOptions": {
    "Host": "FTP_HOST",
    "Username": "FTP_USERNAME",
    "Password": "FTP_PASSWORD",
    "LocalPath": "D:\\Backups",
    "RunAt": "02:00",
    "HistoryCopies": 5,
    "DefaultTimeoutMinutes": 60,
    "RetentionDays": 7,
    "Backups": [
      {
        "Name": "TestUpload",
        "BackupType": "FTP_UPLOAD",
        "Host": "YOUR_FTP_HOST",
        "Port": 21,
        "Username": "FTP_USERNAME",
        "Password": "FTP_PASSWORD",
        "RemotePath": "/",
        "LocalPath": "D:\\Backups",
        "Encryption": "Explicit",
        "Passive": true,
        "AllowInvalidCertificate": true
      }
    ]
  },
  "ServiceSettings": {
    "StartHour": 2,
    "StartMinute": 0
  }
}
